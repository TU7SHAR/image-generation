# AI Image Generation API Keys
#
# NOTE: The app works OUT OF THE BOX with ZERO keys!
# It uses Pollinations.ai (free, no key, no signup) as the default provider.
#
# The keys below are OPTIONAL — only add them if you want to use a specific
# provider or need higher reliability/scale.

# Cloudflare Workers AI (optional - free tier, 10k neurons/day)
# Get it: https://dash.cloudflare.com/ -> AI -> Workers AI
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Together AI (optional - now requires $5 min credit for images)
# Get it: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# HuggingFace (optional - most image models now need PRO credits)
# Get it: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---
# IMAGE EDITING (the /edit page) needs ONE of these:
#
# Option 1 (recommended): Pollinations API key — FREE, GitHub login, no credit card
# Get it: https://enter.pollinations.ai  (create a key, starts with sk_)
POLLINATIONS_API_KEY=
#
# Option 2: Cloudflare keys above also enable image editing (img2img)
# (text-to-image generation still works with NO keys at all)
