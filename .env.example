# AI Image Generation API Keys
# Get your keys from these providers (all have free tiers):

# Cloudflare Workers AI (Best free tier - 10k neurons/day)
# Get it: https://dash.cloudflare.com/ → AI → Workers AI
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# HuggingFace (Free - rate limited)
# Get it: https://huggingface.co/settings/tokens
# Either name works:
HUGGINGFACE_API_TOKEN=
# HUGGINGFACE_API_KEY=

# Together AI (Free credits on signup)
# Get it: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
